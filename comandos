# Comamdos
- Update container
docker update nome_container -m 2048M --cpus 0.9

- Commit imagem
docker commit ID_CONTAINER custom_container:version1

- Salvar (exportar em tar)
docker save custom_container:version1 > custom-container.tar

- Carregar (Carregar em outro host)
docker load < custom-container.tar

- Atualizar politica de restart
docker update --restart always <nome_container>

- Logs e inspecao
docker logs nome_container
docker inspect nome_container

- Ver quais snapshots estao ativos
ctr -n moby snapshots ls

- Limpar snapshots não usados
docker system prune -a

- Limpar build cache
Limpar build cache

-Limpeza de log do apache
docker exec -ti 7 container truncate -s 0 /var/log/apache2/access.log

- Verificar images e limpeza segura
docker image ls
docker image prune -a

- Remover containers parados
docker container prune

- Verificar e remover volumes
docker volume ls
docker volume prune

- Limpar tudo que não esta sendo usado
docker system prune -af --volumes


